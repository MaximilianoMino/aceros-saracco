# Dependencies
node_modules/

# Build Output
# Exclude the directory where TS is transpiled (usually dist, build, or lib)
dist/
build/
out/
lib/

# TypeScript Specific
# Only ignore .js and .js.map if they are generated in the src folder
# src/**/*.js
# src/**/*.js.map
*.tsbuildinfo

# Environment Variables
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE/Editor folders
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
